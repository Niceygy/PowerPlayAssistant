{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch Package",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env"
    },
    {
      "name": "Launch test function",
      "type": "go",
      "request": "launch",
      "mode": "test",
      "envFile": "${workspaceFolder}/.env",
      "program": "${workspaceFolder}/src/tests/pages_test.go",
      "args": [
        "-test.run",
        "TestPages"
      ]
    }
    
    
  ]
}
